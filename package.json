{
  "name": "machine-gun",
  "version": "1.0.0",
  "description": "Dynamic load testing tool and schema driven event simulation platform for RabbitMQ and Kafka.",
  "scripts": {
    "dev": "turbo dev",
    "dev:ui": "pnpm --filter frontend run start",
    "dev:api": "pnpm --filter backend run start:dev",
    "dev:test-consumer": "pnpm --filter test-consumer run start:dev",
    "debug": "turbo run start:debug --filter=backend & pnpm --filter frontend run start",
    "build": "turbo build",
    "build:test-consumer": "pnpm --filter test-consumer run build",
    "test": "turbo test",
    "test:coverage": "turbo run test:cov && open-cli apps/frontend/coverage/frontend/index.html && open-cli apps/backend/coverage/index.html",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "find . -name \"node_modules\" -type d -prune -exec rm -rf '{}' + && find . -name \"dist\" -type d -prune -exec rm -rf '{}' +"
  },
  "keywords": [
    "simulation",
    "event-driven",
    "rabbitmq",
    "kafka",
    "nestjs",
    "angular"
  ],
  "author": "HarryUnchained",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.5.0",
    "open-cli": "^9.0.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.12",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "chokidar",
        "@swc/cli"
      ],
      "allowAny": [
        "chokidar",
        "@swc/cli"
      ]
    }
  }
}