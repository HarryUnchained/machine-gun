{
  "name": "test-consumer",
  "version": "0.0.1",
  "description": "Dynamic load testing tool and schema driven event simulation platform for RabbitMQ and Kafka.",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "dev": "nest start --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "dependencies": {
    "@golevelup/nestjs-rabbitmq": "^9.0.0",
    "@machine-gun/common": "workspace:*",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-fastify": "^11.1.19",
    "dotenv": "^16.6.1",
    "fastify": "^5.8.5",
    "kafkajs": "^2.2.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.33",
    "@types/node": "^22.19.19",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.5.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "typescript-eslint": "^8.59.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.6"
  }
}
