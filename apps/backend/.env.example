# ─── Environment ──────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Message Brokers ──────────────────────────────────────────────────────────
# At least one broker MUST be configured or the application will refuse to start.

# RabbitMQ — set this to enable the RabbitMQ transport
# RABBIT=amqp://guest:guest@localhost:5672

# Kafka — set this to enable the Kafka transport.
# Use localhost:9094 when the backend runs on your host and Kafka runs in docker-compose.
# Use kafka:9092 only from other containers inside the compose network.
# KAFKA=localhost:9094

# ─── Logging ──────────────────────────────────────────────────────────────────
# Comma-separated list of NestJS log levels: log, debug, warn, error, verbose
# LOG_LEVELS=log,debug,warn,error

# ─── Throughput Tuning ────────────────────────────────────────────────────────
# Number of messages generated per worker task. Larger batches reduce scheduler
# overhead and can help high-throughput RabbitMQ/Kafka firehose tests.
# GENERATOR_BATCH_SIZE=2500

# Maximum publish/generation batches allowed to be in flight per active schema.
# Keep this low to prevent the generator from piling up work when the broker lags.
# LOAD_TEST_MAX_IN_FLIGHT_BATCHES=1

# Maximum catch-up window to retain when the generator falls behind. Older backlog
# is dropped so sustained broker pressure lowers actual throughput instead of
# growing memory/CPU queues.
# LOAD_TEST_MAX_BACKLOG_MS=100

# Soft CPU ceiling for the generator process across all cores. Set to 100 for
# benchmark mode; lower it for smoother local development.
# LOAD_TEST_MAX_CPU_PERCENT=85

# Worker-thread pool size for payload generation. Tune against CPU cores and
# broker capacity; too many workers can starve the main publish loop.
# PISCINA_MIN_THREADS=4
# PISCINA_MAX_THREADS=8

# ─── API / Frontend ───────────────────────────────────────────────────────────
# Shared token expected by HTTP auth and the WebSocket dashboard handshake.
# API_KEY=my-super-secret-key

# Allowed frontend origin for backend CORS.
# FRONTEND_URL=http://localhost:4200
