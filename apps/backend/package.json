{
  "name": "backend",
  "version": "0.0.1",
  "description": "Dynamic load testing tool and schema driven event simulation platform for RabbitMQ and Kafka.",
  "author": "",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --inspect --logHeapUsage --threads=false",
    "test:e2e": "vitest run --config ./test/vitest-e2e.config.ts"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/static": "^9.1.3",
    "@golevelup/nestjs-rabbitmq": "^9.0.0",
    "@machine-gun/common": "workspace:*",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-fastify": "^11.1.19",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/websockets": "^11.1.19",
    "amqplib": "^2.0.1",
    "chokidar": "^5.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^16.6.1",
    "fastify": "^5.8.5",
    "joi": "^18.2.1",
    "kafkajs": "^2.2.4",
    "mathjs": "^15.2.0",
    "piscina": "^5.1.4",
    "randexp": "^0.5.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "catalog:",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.33",
    "@types/node": "^22.19.19",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.5.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "typescript-eslint": "^8.59.3",
    "unplugin-swc": "^1.5.9"
  }
}