    "@angular/forms": "^21.2.12",
    "@angular/platform-browser": "^21.2.12",
    "@angular/router": "^21.2.12",
    "@machine-gun/common": "workspace:*",
    "@types/dagre": "^0.7.54",
    "animejs": "^4.4.1",
    "chart.js": "^4.5.1",
    "dagre": "^0.8.5",
    "rxjs": "catalog:",
    "socket.io-client": "^4.8.3",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.10",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.12",
