{
  "name": "frontend",
  "version": "0.0.0",
  "description": "Dynamic load testing tool and schema driven event simulation platform for RabbitMQ and Kafka.",
  "scripts": {
    "start": "ng serve",
    "dev": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false",
    "test:cov": "ng test --watch=false --coverage",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "typecheck": "tsc -p tsconfig.app.json --noEmit"
  },
  "private": true,
  "license": "Apache-2.0",
